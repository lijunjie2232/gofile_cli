# GoFile CLI Environment Configuration
# Copy this file to .env and customize as needed

# Configuration directory (default: ~/.gofile_cli)
# GOFILE_CLI_CONFIG_DIR=/home/user/.config/gofile_cli

# Configuration file name (default: config.json)
# GOFILE_CLI_CONFIG_FILE=config.json

# Default download path (default: ~/Downloads)
# GOFILE_CLI_DOWNLOAD_PATH=/home/user/Downloads

# Enable download verification (default: false)
# GOFILE_CLI_VERIFY_DOWNLOADS=false

# Show progress bars (default: true)
# GOFILE_CLI_SHOW_PROGRESS=true

# Default upload folder (default: null)
# GOFILE_CLI_DEFAULT_UPLOAD_FOLDER=my_uploads

# GoFile API URL (default: https://api.gofile.io)
# GOFILE_CLI_GOFFILE_API_URL=https://api.gofile.io

# MailTM API URL (default: https://api.mail.tm)
# GOFILE_CLI_MAILTM_API_URL=https://api.mail.tm

# Enable debug mode (default: false)
# GOFILE_CLI_DEBUG=false
